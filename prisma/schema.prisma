generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ==================== ENUMS ====================
enum OwnerType {
  INDIVIDUAL
  LEGAL
}

enum AccountType {
  DEBIT
  CREDIT
}

enum TransactionType {
  PAYMENT
  TRANSFER_OUT
  TRANSFER_IN
  INCOME
  REFUND
  CREDIT_PAYMENT
}

// ==================== MODELS ====================

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  hashedPassword String
  firstName      String?
  lastName       String?
  phone          String?   @unique
  birthDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  transactions  Transaction[]
  legalEntities LegalEntity[] // ← Добавили обратную связь

  @@map("users")
}

model LegalEntity {
  id           Int     @id @default(autoincrement())
  name         String
  inn          String  @unique
  ogrn         String?
  kpp          String?
  legalAddress String?
  ownerUserId  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  transactions Transaction[]

  owner User? @relation(fields: [ownerUserId], references: [id])

  @@map("legal_entities")
}

model Account {
  id           Int       @id @default(autoincrement())
  ownerType    OwnerType
  ownerUserId  Int?
  ownerLegalId Int?

  type AccountType

  accountNumber String  @unique
  cardLastFour  String? @db.VarChar(4)
  balance       Decimal @default(0) @db.Decimal(15, 2)
  currency      String  @default("RUB")
  isActive      Boolean @default(true)

  // Кредитные поля
  creditLimit     Decimal? @db.Decimal(15, 2)
  gracePeriodDays Int?
  interestRate    Decimal? @db.Decimal(5, 2)
  minPayment      Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [ownerUserId], references: [id])
  legalEntity  LegalEntity?  @relation(fields: [ownerLegalId], references: [id])
  transactions Transaction[]

  @@map("accounts")
}

model Transaction {
  id           Int       @id @default(autoincrement())
  ownerType    OwnerType
  ownerUserId  Int?
  ownerLegalId Int?

  accountId Int
  amount    Decimal         @db.Decimal(15, 2)
  type      TransactionType

  counterparty String
  description  String?  @db.Text
  date         DateTime @default(now())

  createdAt DateTime @default(now())

  account     Account      @relation(fields: [accountId], references: [id])
  user        User?        @relation(fields: [ownerUserId], references: [id])
  legalEntity LegalEntity? @relation(fields: [ownerLegalId], references: [id])

  @@map("transactions")
}
